<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.baust.cafe">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/cafe_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/cafe_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.BAUSTCafeManagement">

        <!-- Welcome Activity (Main Launcher) -->
        <activity
            android:name=".activities.WelcomeActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".activities.StudentLoginActivity"
            android:exported="false" />

        <!-- Forgot Password Activity -->
        <activity
            android:name=".activities.ForgotPasswordActivity"
            android:exported="false" />

        <!-- Register Activity -->
        <activity
            android:name=".activities.StudentRegisterActivity"
            android:exported="false" />

        <!-- Admin Activities -->
        <activity
            android:name=".activities.AdminLoginActivity"
            android:exported="false" />
        <activity
            android:name=".activities.AdminDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ManageMenuActivity"
            android:exported="false" />
        <activity
            android:name=".activities.ViewOrdersActivity"
            android:exported="false" />
        <activity
            android:name=".activities.OrderHistoryActivity"
            android:exported="false" />
        <activity
            android:name=".activities.CartActivity"
            android:exported="false" />
        <activity
            android:name=".activities.MenuActivity"
            android:exported="false" />

        <activity
            android:name=".activities.HomeActivity"
            android:exported="false" />
        <activity
            android:name=".activities.UserDashboardActivity"
            android:exported="false" />

    </application>

</manifest>