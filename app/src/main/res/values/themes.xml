<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BAUSTCafeManagement" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="android:statusBarColor">@color/primary_green</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Prevent Material3 from overriding button colors -->
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>

        <!-- Splash Screen properties -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/cafe_logo</item>
    </style>

    <style name="Theme.BAUSTCafeManagement" parent="Base.Theme.BAUSTCafeManagement" />
</resources>