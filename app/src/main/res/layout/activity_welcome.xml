<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/welcome_bg"
    tools:context=".activities.WelcomeActivity">

    <LinearLayout
        android:id="@+id/textContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:layout_marginTop="60dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Organic Food"
            android:textColor="@color/white"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Find the freshest food and get\nfast delivery in your town"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:alpha="0.9"
            android:lineSpacingExtra="4dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/getStartedUserButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/welcome_button_bg"
            android:text="Get Started as User"
            android:textAllCaps="false"
            android:textColor="#828F30"
            android:textSize="17sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/getStartedAdminButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/welcome_button_bg"
            android:text="Get Started as Admin"
            android:textAllCaps="false"
            android:textColor="#828F30"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ImageView
        android:id="@+id/welcomeImageView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:contentDescription="@string/welcome_image_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/welcoming"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textContainer" />

</androidx.constraintlayout.widget.ConstraintLayout>